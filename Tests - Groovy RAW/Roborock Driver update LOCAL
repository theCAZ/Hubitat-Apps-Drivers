def refresh(Map data = [type: 1]) {
    logDebug "executing 'refresh()'"
    pollStatus()
    if (data?.type == 1) {
        // Full refresh — also re-check home data every 2 min
        Long last = state?.lastHomeDataRefresh ?: 0
        if ((now() - last) > 120000) {
            state.lastHomeDataRefresh = now()
            runIn(5, "syncRoomsLocal")
        }
    }
}

def selectDevice() {
    String deviceId = findNextDevice(state?.duid)
    if (state?.duid != deviceId) {
        state?.duid = deviceId
        clearAttributes()
        initialize()
    } else {
        logInfo "device id is ${getDeviceId()}"
    }
}

