// ── Local TCP send/receive ─────────────────────────────────────────────────────
void localExecute(String command, String args = null) {
    def param = args ? convertNumbers((new JsonSlurper().parseText(args))) : []
    logInfo "localExecute: command=${command} param=${param}"

    Integer id = (Integer) (state.sequence++ & 0xFFFFFFFF)
    String deviceId = getDeviceId()
    if (!deviceId) { logWarn "no device ID — run syncFromCloud first"; return }

    Integer timestamp = (Integer) (now() / 1000)
    Integer protocol = 101

    Map inner = [id: id, method: command, params: param]
    String payload = JsonOutput.toJson([t: timestamp, dps: ["$protocol": JsonOutput.toJson(inner)]])

    byte[] message = buildLocalMessage(deviceId, protocol, timestamp, payload.getBytes("UTF-8"))

    // Track pending command for response matching
    if (!state.pendingCmds) state.pendingCmds = [:]
    state.pendingCmds[id.toString()] = [command: command, param: param, ts: now()]

    try {
        interfaces.rawSocket.sendMessage(message.encodeHex().toString())
        logDebug "sent local command id=${id} command=${command}"
    } catch (Exception e) {
        logWarn "local send failed: ${e.message} — reconnecting"
        state.localConnected = false
        scheduleReconnect()
    }
}

byte[] buildLocalMessage(String deviceId, Integer protocol, Integer timestamp, byte[] payload) {
    String localKey = getLocalKey(deviceId)
    if (!localKey) { logWarn "no localKey for device ${deviceId}"; return new byte[0] }

    String key = encodeTimestamp(timestamp) + localKey + salt
    byte[] encrypted = encrypt(payload, key)

    Random random = new Random()
    Integer randomInt = random.nextInt(900000) + 100000

    // Local protocol: 4-byte length prefix + standard header + payload
    // Header: version(3) + sequence(4) + random(4) + timestamp(4) + protocol(2) + payloadLen(2)
    int headerLen = 19
    int totalMsgLen = headerLen + encrypted.length + 4  // +4 for CRC32
    byte[] msg = new byte[totalMsgLen]

    // version "1.0"
    msg[0] = 49; msg[1] = 46; msg[2] = 48
    writeInt32BE(msg, (Integer) (state.sequence & 0xFFFFFFFF), 3)
    writeInt32BE(msg, (Integer) (randomInt & 0xFFFFFFFF), 7)
    writeInt32BE(msg, timestamp, 11)
    writeInt16BE(msg, protocol, 15)
    writeInt16BE(msg, encrypted.length, 17)
    for (Integer i = 0; i < encrypted.length; i++) { msg[headerLen + i] = encrypted[i] }
    Integer crc32 = CRC32(msg, msg.length - 4)
    writeInt32BE(msg, crc32, msg.length - 4)

    // Local TCP wraps with 4-byte big-endian length prefix
    int frameLen = totalMsgLen
    byte[] frame = new byte[4 + frameLen]
    frame[0] = (byte) ((frameLen >> 24) & 0xFF)
    frame[1] = (byte) ((frameLen >> 16) & 0xFF)
    frame[2] = (byte) ((frameLen >> 8) & 0xFF)
    frame[3] = (byte) (frameLen & 0xFF)
    for (Integer i = 0; i < frameLen; i++) { frame[4 + i] = msg[i] }
    return frame
}

// ── Parse incoming local TCP messages ────────────────────────────────────────
// Hubitat calls parse(String hex) for rawSocket byteInterface
def parse(String hexMessage) {
    logDebug "parse() received ${hexMessage?.length()} hex chars"
    try {
        byte[] raw = hexMessage.decodeHex()
        parseLocalMessage(raw)
    } catch (Exception e) {
        logWarn "parse() error: ${e.message}"
    }
}

void parseLocalMessage(byte[] raw) {
    // Strip 4-byte length prefix if present
    byte[] message = raw
    if (raw.length > 4) {
        Integer declaredLen = readInt32BE(raw, 0)
        if (declaredLen == raw.length - 4) {
            message = raw[4..(raw.length - 1)] as byte[]
        }
    }

    if (message.length < 23) { logWarn "message too short: ${message.length}"; return }

    String version = bytesToString(message, 0, 3)
    if (version != "1.0") { logWarn "unexpected version: ${version}"; return }

    Integer crc32 = CRC32(message, message.length - 4)
    Integer expectedCrc = readInt32BE(message, message.length - 4)
    if (crc32 != expectedCrc) { logWarn "CRC mismatch"; return }

    Integer timestamp  = readInt32BE(message, 11)
    Integer protocol   = readInt16BE(message, 15)
    Integer payloadLen = readInt16BE(message, 17)

    if (protocol != 102) { logDebug "ignoring protocol ${protocol}"; return }

    byte[] payload = message[19..(19 + payloadLen - 1)]
    String deviceId = getDeviceId()
    String localKey = getLocalKey(deviceId)
    if (!localKey) { logWarn "no localKey to decrypt"; return }

    String key = encodeTimestamp(timestamp) + localKey + salt
    byte[] decrypted = decrypt(payload, key)

    Map jsonObject = [:]
    try {
        jsonObject = new JsonSlurper().parseText(new String(decrypted, "UTF-8"))
    } catch (Exception e) {
        logWarn "response not JSON: ${e.message}"; return
    }

    if (!jsonObject) return
    logDebug "parsed local response: ${jsonObject}"

    // Mark as online since we got a valid response
    state.lastLocalSuccess = now()
    state.localConnected = true
    setHealthStatusOnline()

    processLocalResponse(jsonObject)
}

void processLocalResponse(Map resp) {
    // Response format: { id: N, result: [...] } or { dps: {...} }
    if (resp?.result != null) {
        Integer id = resp?.id?.toInteger()
        Map pending = state?.pendingCmds?.get(id?.toString())

        // Clean up pending
        if (pending) {
            state.pendingCmds.remove(id.toString())
            logDebug "matched response for command: ${pending?.command}"
        }

        String cmd = pending?.command ?: ""

        if (cmd == "get_prop" || resp?.result?.any { it instanceof Map && it.containsKey("state") }) {
            resp?.result?.each { result ->
                if (result instanceof Map) {
                    result.switch = ((result?.in_cleaning ?: 0).toInteger() != 0 ||
                                    (result?.is_locating ?: 0).toInteger() != 0 ||
                                    (result?.is_exploring ?: 0).toInteger() != 0) ? "on" : "off"
                    if (result?.battery?.toInteger() == 100 && result?.state?.toInteger() == 8) result.state = 100
                    if (result?.clean_percent?.toInteger() == 0 && result?.clean_area?.toInteger() > 1) result.clean_percent = 100
                    result?.each { c, v -> processEvent(c as String, v) }
                }
            }
            if (settings?.tileEnable)   scheduleTileUpdate()
            if (settings?.xxTileEnable) scheduleXxTileUpdate()
        } else if (cmd == "get_consumable") {
            resp?.result?.each { result ->
                if (result instanceof Map) result?.each { c, v -> processEvent(c as String, v) }
            }
            if (settings?.tileEnable)   scheduleTileUpdate()
            if (settings?.xxTileEnable) scheduleXxTileUpdate()
        } else if (cmd == "get_room_mapping") {
            setRoomsValue(resp)
        } else if (cmd == "get_water_box_custom_mode" && resp?.result?.water_box_mode) {
            processEvent(cmd, resp.result.water_box_mode)
        } else if (resp?.result == ["ok"] || resp?.result == ["OK"]) {
            logInfo "command '${cmd}' accepted"
            runIn(3, "pollStatus")
        } else {
            logDebug "unhandled response for cmd=${cmd}: ${resp}"
        }
    } else if (resp?.dps) {
        // Unsolicited DPS push from vacuum
        resp.dps.each { key, value -> processEvent(key as String, value) }
        if (settings?.tileEnable)   scheduleTileUpdate()
        if (settings?.xxTileEnable) scheduleXxTileUpdate()
    }
}

void setHealthStatusOnline() {
    String current = device.currentValue("healthStatus")
    if (current != "online") {
        processEvent("healthStatus", "online")
        sendEvent(name: "connectionMode", value: "local")
    }
}

// ── Cloud home data (one-time / on-demand) ────────────────────────────────────
void getHomeDataCallback() {
    logDebug "getHomeDataCallback()"
    Boolean deviceOnline = !!(getHomeDataResult()?.devices?.find { it.duid?.toString() == getDeviceId() }?.online)
    if (!deviceOnline) {
        logWarn "device appears offline in cloud home data"
        processEvent("state", 256)
    }

    // Save device IP from home data if not already set by user preference
    if (!settings?.deviceIP) {
        String ip = getHomeDataResult()?.devices?.find { it.duid?.toString() == getDeviceId() }?.ip
        if (ip) {
            logInfo "discovered vacuum IP from cloud: ${ip}"
            state.discoveredIP = ip
        }
    }

    String name = getHomeDataResult()?.devices?.find { it.duid?.toString() == getDeviceId() }?.name ?: "unknown"
    processEvent("name", name)

    // Pull rooms and scenes from cloud, then switch to local
    localExecute_afterCloudSync()
    runIn(5, "startLocalMode")
}

