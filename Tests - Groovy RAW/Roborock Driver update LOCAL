// ── Logging ──────────────────────────────────────────────────────────────────
private Boolean isInfoEnabled()  { def s = settings?.deviceLogging ?: "off"; return s.startsWith("info") || s.startsWith("debug") }
private Boolean isDebugEnabled() { def s = settings?.deviceLogging ?: "off"; return s.startsWith("debug") }
def logInfo(msg)  { if (isInfoEnabled())  log.info  "${device.displayName} ${msg}" }
def logDebug(msg) { if (isDebugEnabled()) log.debug "${device.displayName} ${msg}" }
def logTrace(msg) { if (isDebugEnabled()) log.trace "${device.displayName} ${msg}" }
def logWarn(msg)  { log.warn  "${device.displayName} ${msg}" }
def logError(msg) { log.error "${device.displayName} ${msg}" }

def logsOff() {
    log.info "${device.displayName} auto-disabling logging"
    device.updateSetting("deviceLogging", [value: "off", type: "enum"])
}
void scheduleLogsOff() {
    unschedule('logsOff')
    def s = settings?.deviceLogging ?: "off"
    if (s == "off") return
    def minutes = s.endsWith("60") ? 60 : 30
    runIn(minutes * 60, "logsOff")
}

// ── Lifecycle ─────────────────────────────────────────────────────────────────
def installed() { initialize() }

def updated() {
    cleanStaleAttributes()
    scheduleLogsOff()
    initialize()
    scheduleLogsOff()
}

def initialize() {
    unschedule()
    scheduleLogsOff()
    sendEvent(name: "numberOfButtons", value: (settings?.numberOfButtons) ?: 1)
    localDisconnect()

    if (settings?.allowLogin && settings?.username && settings?.password) {
        logInfo "executing 'initialize()' — cloud login"
        state?.keySet()?.collect()?.each { state.remove(it) }
        state.sequence = (new Random().nextInt(2000) + 1)
        clearAttributes()

        Map login = login()
        device.updateSetting("allowLogin", [value: 'false', type: "bool"])

        if (login?.msg == "success") {
            runIn(1, "getHomeDetail")
        } else {
            logWarn "login failed: ${login?.msg}"
            processEvent("state", 500)
        }
    } else if (state?.login) {
        // Already have credentials — skip cloud, go straight to local
        runIn(2, "startLocalMode")
    }
}

// ── Cloud login flow (one-time) ───────────────────────────────────────────────
def zRequestEmailCode() {
    if (state.sendEmailCodeTimestamp) {
        Long remaining = (state.sendEmailCodeTimestamp as Long) + 60000 - now()
        if (remaining > 0) { logWarn "wait ${(remaining / 1000).toInteger()}s before requesting again"; return }
    }
    state.sendEmailCodeTimestamp = now()
    Map result = sendEmailCode()
    if (result.msg == "success") { processEvent("state", 502) }
    else { logWarn "request email code failed: ${result?.msg}"; processEvent("state", 504) }
}

def zAuthorizeEmailCode(String pin) {
    logInfo "executing 'zAuthorizeEmailCode($pin)'"
    if (!pin || !state?.sendEmailCodeTimestamp || now() > ((state.sendEmailCodeTimestamp as Long) + 15 * 60 * 1000)) {
        logWarn "code expired or missing"; return
    }
    Map result = loginWithCode(pin)
    if (result?.msg == "success") {
        processEvent("state", 503)
        runIn(1, "getHomeDetail")
        state.remove("sendEmailCodeTimestamp")
    } else {
        logWarn "authorize email code failed: ${result?.msg}"
        processEvent("state", 500)
    }
}

// ── Local TCP mode ────────────────────────────────────────────────────────────
void startLocalMode() {
    logInfo "starting local TCP mode"
    String ip = getVacuumIP()
    if (!ip) {
        logWarn "no local IP known — check 'Vacuum Local IP Address' preference or run syncFromCloud"
        processEvent("healthStatus", "offline")
        sendEvent(name: "connectionMode", value: "offline")
        return
    }
    sendEvent(name: "localIP", value: ip)
    sendEvent(name: "connectionMode", value: "local")
    localConnect()
    schedulePoll()
}

void localConnect() {
    String ip = getVacuumIP()
    if (!ip) return
    logInfo "connecting local TCP to ${ip}:${ROBOROCK_LOCAL_PORT}"
    try {
        interfaces.rawSocket.connect(ip, ROBOROCK_LOCAL_PORT, byteInterface: true, readDelay: 150)
        state.localConnected = true
        state.lastLocalSuccess = now()
        logInfo "local TCP connected"
    } catch (Exception e) {
        logWarn "local TCP connect failed: ${e.message}"
        state.localConnected = false
        scheduleReconnect()
    }
}

void localDisconnect() {
    try { interfaces.rawSocket.close() } catch (Exception e) { /* ignore */ }
    state.localConnected = false
}

void socketStatus(String message) {
    logDebug "socketStatus: ${message}"
    if (message?.toLowerCase()?.contains("error") || message?.toLowerCase()?.contains("closed")) {
        logWarn "local TCP socket issue: ${message}"
        state.localConnected = false
        scheduleReconnect()
        checkOfflineThreshold()
    }
}

void scheduleReconnect() {
    logInfo "scheduling local TCP reconnect in 15s"
    runIn(15, "localConnect")
}

void checkOfflineThreshold() {
    Integer threshold = (settings?.offlineThreshold ?: 90).toInteger()
    Long lastSuccess = state?.lastLocalSuccess ?: 0
    if ((now() - lastSuccess) > (threshold * 1000)) {
        logWarn "exceeded offline threshold (${threshold}s) — marking offline"
        processEvent("healthStatus", "offline")
        sendEvent(name: "connectionMode", value: "offline")
        if (settings?.tileEnable)   scheduleTileUpdate()
        if (settings?.xxTileEnable) scheduleXxTileUpdate()
    }
}

// ── Polling ───────────────────────────────────────────────────────────────────
void schedulePoll() {
    Integer interval = (settings?.pollInterval ?: "30").toInteger()
    logDebug "scheduling poll every ${interval}s"
    // Unschedule any existing poll jobs then re-schedule
    unschedule('pollStatus')
    if (interval == 15)  runEvery15Seconds('pollStatus')  // not standard — use runIn loop
    else if (interval == 30) schedule("0/${interval} * * * * ?", "pollStatus")
    else if (interval == 60) runEvery1Minute('pollStatus')
    else if (interval == 120) runEvery2Minutes('pollStatus')
    // kick off first poll immediately
    runIn(2, "pollStatus")
}

void pollStatus() {
    logDebug "polling vacuum status locally"
    if (!state?.localConnected) {
        localConnect()
        runIn(3, "doPollCommands")
    } else {
        doPollCommands()
    }
}

void doPollCommands() {
    localExecute("get_prop", """["get_status"]""")
    // Stagger consumable poll — only every 5th cycle to reduce traffic
    state.pollCount = ((state?.pollCount ?: 0).toInteger() + 1)
    if (state.pollCount % 5 == 0) {
        runIn(2, "pollConsumables")
    }
}

void pollConsumables() {
    localExecute("get_consumable")
}

