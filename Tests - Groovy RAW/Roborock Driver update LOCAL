// Salt is hardcoded in librrcodec.so — same for local and cloud protocols
@Field static final String salt = "TXdfu\$jyZ#TZHsg4"

// Local TCP port the vacuum listens on
@Field static final Integer ROBOROCK_LOCAL_PORT = 58867

// Consumable life hours — adjust per your model
@Field static final Map life = [main: 300, side: 200, filter: 150, sensor: 30, highSpeed: 300]

// How often to poll (seconds). 30s is a good balance.
@Field static final Integer POLL_INTERVAL = 30

