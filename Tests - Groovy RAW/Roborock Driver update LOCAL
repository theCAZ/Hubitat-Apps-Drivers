// ── processEvent — identical to original driver ───────────────────────────────
void processEvent(String name, def value) {
    logTrace "processEvent($name, $value)"
    switch (name) {
        case "get_water_box_custom_mode":
            String ve = mopWaterModeCodes[value?.toInteger()]?.toLowerCase() ?: value
            sendEventX(name: "mopWaterMode", value: ve, descriptionText: "mop water mode is $ve ($value)"); break
        case "switch":
            sendEventX(name: "switch", value: value, descriptionText: "switch is $value"); break
        case "name":
            sendEventX(name: "name", value: value, descriptionText: "name set to $value"); break
        case "healthStatus":
            sendEventX(name: "healthStatus", value: value, descriptionText: "healthStatus set to $value",
                       logLevel: (value == "online" ? "info" : "warn")); break
        case "rooms":
            String roomsList = value?.sort { a, b -> a.key.toInteger() <=> b.key.toInteger() }
                                    ?.findAll { k, v -> v != null }
                                    ?.collect { k, v -> "$k: $v" }?.join(" | ")
            sendEventX(name: "roomsList", value: roomsList); break
        case "scenes":
            String scenesList = value?.sort { a, b -> a.key.toInteger() <=> b.key.toInteger() }
                                     ?.collect { k, v -> "$k: $v" }?.join(" | ")
            sendEventX(name: "scenesList", value: scenesList); break
        case "error_code":
            String ve = errorCodes[value?.toInteger()]?.toLowerCase() ?: value
            sendEventX(name: "error", value: ve, descriptionText: "error is $ve ($value)",
                       logLevel: (value == 0 ? "info" : "warn")); break
        case "state":
            String ve = stateCodes[value?.toInteger()]?.toLowerCase() ?: value
            sendEventX(name: "state", value: ve, descriptionText: "state is $ve ($value)"); break
        case "battery":
            sendEventX(name: "battery", value: value.toInteger(), unit: "%",
                       descriptionText: "battery level is $value%"); break
        case "fan_power":
            String ve = fanPowerCodes[value?.toInteger()]?.toLowerCase() ?: value
            sendEventX(name: "fanPower", value: ve, descriptionText: "fan power is $ve ($value)"); break
        case "main_brush_work_time":
            Integer p = Math.max(0, (100 - Math.floor((value.toInteger() / (life.main * 3600)) * 100).toInteger()))
            sendEventX(name: "remainingMainBrush (%)", value: p, unit: "%",
                       descriptionText: "main brush remaining is $p%"); break
        case "side_brush_work_time":
            Integer p = Math.max(0, (100 - Math.floor((value.toInteger() / (life.side * 3600)) * 100).toInteger()))
            sendEventX(name: "remainingSideBrush (%)", value: p, unit: "%",
                       descriptionText: "side brush remaining is $p%"); break
        case "cleaning_brush_work_times":
            Integer p = Math.max(0, (100 - Math.floor((value.toInteger() / life.highSpeed) * 100).toInteger()))
            sendEventX(name: "remainingHighSpeedMaintBrush (%)", value: p, unit: "%",
                       descriptionText: "high-speed brush remaining is $p%"); break
        case "sensor_dirty_time":
            Integer p = Math.max(0, (100 - Math.floor((value.toInteger() / (life.sensor * 3600)) * 100).toInteger()))
            sendEventX(name: "remainingSensors (%)", value: p, unit: "%",
                       descriptionText: "sensor remaining is $p%"); break
        case "clean_time":
            Integer mins = Math.ceil(value.toInteger() / 60).toInteger()
            sendEventX(name: "cleanTime (min)", value: mins,
                       descriptionText: "clean time is $mins min", eventDisable: cleanAttributeDisable); break
        case "clean_area":
            String unit = (areaUnit == null || areaUnit == "0") ? "sq ft" : "m²"
            Integer area = (unit == "sq ft") ? value.toInteger() / 92903.04 : value.toInteger() / 1000000
            sendEventX(name: "cleanArea (sq ft)", value: area,
                       descriptionText: "clean area is $area $unit", eventDisable: cleanAttributeDisable); break
        case "is_locating":
            String loc = (value == 0 ? "false" : "true")
            sendEventX(name: "locating", value: loc, descriptionText: "locating is $loc ($value)"); break
        case "dust_collection_status":
            String dc = (value == 0 ? "off" : "on")
            sendEventX(name: "dustCollection", value: dc, descriptionText: "dust collection is $dc ($value)"); break
        case "mop_mode":
            String ve = mopModeCodes[value?.toInteger()]?.toLowerCase() ?: value
            sendEventX(name: "mopMode", value: ve, descriptionText: "mop mode is $ve ($value)"); break
        case "dock_error_status":
            String ve = dockErrorCodes[value?.toInteger()]?.toLowerCase() ?: value
            sendEventX(name: "dockError", value: ve, descriptionText: "dock error is $ve ($value)",
                       logLevel: (value == 0 ? "info" : "warn")); break
        case "clean_percent":
            sendEventX(name: "cleanPercent (%)", value: value.toInteger(), unit: "%",
                       descriptionText: "percent completed is $value%", eventDisable: cleanAttributeDisable); break
        case "strainer_work_times":
            Integer p = Math.max(0, (100 - Math.floor((value.toInteger() / life.filter) * 100).toInteger()))
            sendEventX(name: "remainingFilter (%)", value: p, unit: "%",
                       descriptionText: "filter remaining is $p%"); break
        default:
            if (isDebugEnabled()) logDebug "unhandled event: $name = $value"; break
    }
}

void sendEventX(Map x) {
    if (x?.value != null && !x?.eventDisable &&
        (device.currentValue(x?.name).toString() != x?.value.toString() || x?.isStateChange)) {
        if (x?.descriptionText) {
            if (x?.logLevel == "warn") logWarn(x?.descriptionText)
            else logInfo(x?.descriptionText)
        }
        sendEvent(name: x?.name, value: x?.value, unit: x?.unit,
                  descriptionText: x?.descriptionText, isStateChange: (x?.isStateChange ?: false))
    }
}

