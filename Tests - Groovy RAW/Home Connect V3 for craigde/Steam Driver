/* ===========================================================================================================
   STREAM HEALTH MONITOR
   
   Replaces the aggressive watchdog. Does ONE thing: logs a WARNING if no SSE data
   has arrived for longer than streamHealthAlertMinutes. Never forces a reconnect —
   Hubitat's eventStreamStatus() already handles that cleanly.
   =========================================================================================================== */

def streamHealthMonitor() {
    def alertMinutes = (settings?.streamHealthAlertMinutes ?: "10").toInteger()
    if (alertMinutes == 0) return   // Monitoring disabled

    def currentStatus = device.currentValue("connectionStatus")

    // Only alert when we think we're connected — don't spam during known disconnects
    if (currentStatus != "connected") {
        logDebug("Stream health monitor: status is '${currentStatus}' — skipping check")
        return
    }
    if (state.rateLimitedUntil && now() < state.rateLimitedUntil) {
        logDebug("Stream health monitor: rate limited — skipping check")
        return
    }

    def lastParse = state.lastParseTime ?: state.connectionStartTime ?: 0
    if (lastParse == 0) {
        logDebug("Stream health monitor: no timestamp available — skipping")
        return
    }

    def silentMs  = now() - lastParse
    def silentMin = (silentMs / 60000).toInteger()
    def silentSec = (silentMs / 1000).toInteger()

    if (silentMs > (alertMinutes * 60 * 1000)) {
        logWarn("Stream health: no data received for ${silentMin}min ${silentSec % 60}s " +
                "(threshold: ${alertMinutes}min). Stream may have dropped silently. " +
                "Hubitat will reconnect automatically if connection is lost. " +
                "If events have stopped flowing, click Reconnect on the device page.")
        sendEvent(name: "connectionStatus", value: "connected - no data for ${silentMin}min")
    } else {
        logDebug("Stream health monitor: OK — last data ${silentSec}s ago")
    }
}

private void logStreamHealthDiagnostics(long parseElapsedMs) {
    def lastRealEvent    = state.lastRealEventTime ?: 0
    def realEventElapsed = lastRealEvent > 0 ? (now() - lastRealEvent) : -1
    def keepAliveCount   = state.eventStats?.get("KEEP-ALIVE") ?: 0
    def connectionAge    = state.connectionStartTime ? (now() - state.connectionStartTime) : 0

    logInfo("=== STREAM HEALTH DIAGNOSTICS ===")
    logInfo("Connection age:     ${(connectionAge/1000).toInteger()}s")
    logInfo("Last ANY data:      ${(parseElapsedMs/1000).toInteger()}s ago")
    logInfo("Alert threshold:    ${settings?.streamHealthAlertMinutes ?: 10}min")
    logInfo("Device refresh:     ${settings?.disableBackgroundPolling ? 'DISABLED on reconnect' : 'enabled on reconnect'}")
    if (realEventElapsed >= 0) {
        logInfo("Last REAL event:    ${(realEventElapsed/1000).toInteger()}s ago (${state.lastRealEventType ?: 'unknown'})")
    } else {
        logInfo("Last REAL event:    NEVER (only KEEP-ALIVEs)")
    }
    logInfo("KEEP-ALIVE count:   ${keepAliveCount}")
    logInfo("Buffer size:        ${messageBuffer?.length() ?: 0} chars")
    if (state.applianceLastEventTime) {
        logInfo("--- Per-Appliance Last Event ---")
        state.applianceLastEventTime.each { haId, timestamp ->
            def ago      = ((now() - timestamp) / 1000).toInteger()
            def lastType = state.applianceLastEventType?.get(haId) ?: "unknown"
            def lastKey  = state.applianceLastEventKey?.get(haId)  ?: "unknown"
            logInfo("  ${haId}: ${ago}s ago [${lastType}] ${lastKey}")
        }
    }
    if (state.eventStats) {
        logInfo("--- Event Type Counts ---")
        state.eventStats.each { type, count -> logInfo("  ${type}: ${count}") }
    }
    logInfo("=================================")
}

private void handleFollowUpRequestsError(String status) {
    logWarn("ProtocolException: Too many follow-up requests")
    logWarn("This may indicate OAuth token issues or API endpoint problems")

    def matcher      = status =~ /follow-up requests: (\d+)/
    def redirectCount = (matcher && matcher.size() > 0 && matcher[0].size() > 1) ? matcher[0][1].toInteger() : 21
    logWarn("HTTP client followed ${redirectCount} redirects before failing")

    def connectionStart = state.connectionStartTime ?: 0
    if (connectionStart > 0) {
        logWarn("Connection lasted ${((now() - connectionStart)/1000)}s before ProtocolException")
    }

    try {
        def tokenExpires = parent?.getTokenExpiryTime() ?: 0
        if (tokenExpires > 0) logWarn("OAuth token still valid for ${(tokenExpires - now())/1000}s at time of error")
    } catch (Exception e) { /* ignore */ }

    unschedule("connect")
    parent?.refreshOAuthTokenAndRetry()

    state.connectionSucceeded   = false
    state.reconnectAttempts     = 0
    def delay = 60
    state.pendingReconnectTime  = now() + (delay * 1000)

    logWarn("Scheduling reconnect after ProtocolException: ${delay}s")
    sendEvent(name: "connectionStatus", value: "disconnected - protocol error")
    runIn(delay, "connect")
}

/* ===========================================================================================================
   SSE PARSING
   =========================================================================================================== */

def parse(String text) {
    checkDriverVersion()

    if (state.rateLimitedUntil && now() < state.rateLimitedUntil) return

    logDebug("Raw SSE data: ${text?.take(200)}${(text?.length() ?: 0) > 200 ? '...' : ''}")

    state.lastParseTime = now()

    // Correct stale connectionStatus — parse() proves the stream is alive
    def currentStatus = device.currentValue("connectionStatus")
    if (currentStatus != "connected") {
        logInfo("Stream receiving data but status was '${currentStatus}' — correcting to 'connected'")
        sendEvent(name: "connectionStatus", value: "connected")
        state.connectionSucceeded  = true
        state.processingDisconnect = false
        unschedule("connect")
    }

    // FIX: Throttle lastEventReceived sendEvent to max once per minute
    // Previously fired on EVERY parse() call including keep-alives — ~2600 events/day
    updateLastEventReceived()

    if (text && (text.contains('"key": "429"') || text.contains('"key":"429"') || text.contains("rate limit"))) {
        handleRateLimitError(text)
        return
    }

    messageBuffer += (text ?: "") + "\n"

    while (messageBuffer.contains("\n\n")) {
        def idx     = messageBuffer.indexOf("\n\n")
        def message = messageBuffer.substring(0, idx)
        messageBuffer = messageBuffer.substring(idx + 2)
        processSSEMessage(message)
    }

    if (messageBuffer.length() > 10000) {
        logWarn("SSE message buffer exceeded 10KB (${messageBuffer.length()} chars) — clearing stale data")
        messageBuffer = ""
    }
}

/**
 * FIX: Throttled to fire sendEvent max once per minute.
 * Original fired on every parse() including keep-alives = ~2600 attribute events/day.
 */
private void updateLastEventReceived() {
    def lastUpdate = state.lastEventReceivedUpdate ?: 0
    if ((now() - lastUpdate) < 60000) return   // Throttle: max once per minute
    state.lastEventReceivedUpdate = now()
    def now2 = new Date()
    sendEvent(name: "lastEventReceived", value: now2.format("yyyy-MM-dd'T'HH:mm:ss.SSSZ"))
    sendEvent(name: "lastEventTime",     value: now2.format("yyyy-MM-dd HH:mm:ss"))
}

private void updateEventStats(String eventType) {
    if (!state.eventStats) state.eventStats = [:]
    state.eventStats[eventType] = (state.eventStats[eventType] ?: 0) + 1
    if (eventType != "KEEP-ALIVE") {
        state.lastRealEventTime = now()
        state.lastRealEventType = eventType
        logDebug("Real event received: ${eventType} (total: ${state.eventStats[eventType]})")
    }
}

private void trackApplianceEvent(String haId, String eventType, String eventKey) {
    if (!state.applianceLastEventTime) state.applianceLastEventTime = [:]
    if (!state.applianceLastEventType) state.applianceLastEventType = [:]
    if (!state.applianceLastEventKey)  state.applianceLastEventKey  = [:]
    state.applianceLastEventTime[haId] = now()
    state.applianceLastEventType[haId] = eventType
    state.applianceLastEventKey[haId]  = eventKey
}

private void handleRateLimitError(String text) {
    logError("Rate limit detected in SSE stream — stopping reconnects")
    def matcher       = text =~ /(\d+) seconds/
    def backoffSeconds= (matcher && matcher.size() > 0 && matcher[0].size() > 1) ? matcher[0][1].toInteger() : 86400
    def rateLimitUntil= now() + (backoffSeconds * 1000)
    state.rateLimitedUntil          = rateLimitUntil
    state.rateLimitedUntilFormatted = formatDateTime(rateLimitUntil)
    state.reconnectAttempts         = 0
    state.rateLimitWarningSent      = true   // Suppress duplicate error logs

    sendEvent(name: "connectionStatus",   value: "rate limited until ${state.rateLimitedUntilFormatted}")
    sendEvent(name: "rateLimitRemaining", value: 0)
    logError("Rate limited until ${state.rateLimitedUntilFormatted}")

    def reconnectDelay = backoffSeconds + RATE_LIMIT_BUFFER
    logInfo("Scheduling automatic reconnect in ${reconnectDelay}s (${formatDateTime(now() + reconnectDelay * 1000)})")
    state.pendingReconnectTime = now() + (reconnectDelay * 1000)
    runIn(reconnectDelay, "connect")
}

private void processSSEMessage(String message) {
    logDebug("Processing SSE message: ${message?.take(100)}${(message?.length() ?: 0) > 100 ? '...' : ''}")

    String  eventType    = null
    String  dataPayload  = null
    boolean hasDataField = false

    message.split("\n").each { line ->
        if (line.startsWith("event:") && line.length() > 6) {
            eventType = line.substring(6).trim()
        } else if (line.startsWith("data:")) {
            hasDataField = true
            def value = line.length() > 5 ? line.substring(5).trim() : ""
            if (value) dataPayload = value
        }
    }

    if (!dataPayload) {
        message.split("\n").each { line ->
            if (!dataPayload && line.startsWith("{")) dataPayload = line.trim()
        }
    }

    if      (eventType && dataPayload) { processEventPayload(dataPayload, eventType) }
    else if (dataPayload)              { processEventPayload(dataPayload) }
    else if (hasDataField && !dataPayload) {
        logDebug("Keep-alive received (empty data field)")
        updateEventStats("KEEP-ALIVE")
    }
}

private void processEventPayload(String payload, String eventType = null) {
    if (!payload || !payload.startsWith("{")) return
    try {
        def json = new JsonSlurper().parseText(payload)
        String haId = json.haId
        if (!haId) { logWarn("Event payload missing haId — ignoring"); return }

        if (eventType == "KEEP-ALIVE") {
            logDebug("Keep-alive for appliance ${haId}")
            updateEventStats("KEEP-ALIVE")
            return
        }

        if (eventType == "DISCONNECTED" || eventType == "CONNECTED") {
            logInfo("Appliance ${haId} is now ${eventType}")
            updateEventStats(eventType)
            trackApplianceEvent(haId, eventType, eventType)
            parent?.handleApplianceConnectionEvent(haId, eventType)
            return
        }

        def items = json.items
        if (items instanceof List) {
            items.findAll { it != null && it.key != null }.each { item ->
                def evt = [
                    haId        : haId,
                    key         : item.key,
                    value       : item.value,
                    displayvalue: item.displayvalue ?: item.value?.toString(),
                    unit        : item.unit,
                    eventType   : eventType
                ]
                logDebug("Event: ${eventType} — ${item.key} = ${item.value} for ${haId}")
                updateEventStats(eventType ?: "STATUS")
                trackApplianceEvent(haId, eventType ?: "STATUS", item.key)
                parent?.handleApplianceEvent(evt)
            }
        } else {
            logDebug("Event payload has no items array — eventType: ${eventType}, haId: ${haId}")
        }
    } catch (Exception e) {
        logError("Error parsing event payload: ${e.message}")
        logError("Payload: ${payload?.take(200)}")
    }
}

