/**
 * FIX: Removed logDebug("Response headers: ${headerNames}") from header iteration loop.
 * Original logged ALL response header names on EVERY API call even with debugLogging on.
 * Now only logged at trace level.
 */
private void extractRateLimitHeaders(response) {
    try {
        def headers = response.headers
        if (headers == null) { logDebug("extractRateLimitHeaders: response.headers is null"); return }

        // Trace-only header dump (was debug — caused log spam)
        if (settings?.traceLogging) {
            def headerNames = []
            headers.each { headerNames << it.name }
            log.trace "Home Connect Stream: Response headers: ${headerNames}"
        }

        String remaining = null
        String limit     = null
        headers.each { hdr ->
            if (hdr.name?.equalsIgnoreCase('X-RateLimit-Remaining') || hdr.name?.equalsIgnoreCase('RateLimit-Remaining')) remaining = hdr.value
            if (hdr.name?.equalsIgnoreCase('X-RateLimit-Limit')     || hdr.name?.equalsIgnoreCase('RateLimit-Limit'))     limit     = hdr.value
        }

        logDebug("Rate limit headers — remaining: ${remaining}, limit: ${limit}")

        if (remaining != null) {
            def remainingInt      = remaining.toString().trim().toInteger()
            def previousRemaining = device.currentValue("rateLimitRemaining") as Integer
            sendEvent(name: "rateLimitRemaining", value: remainingInt)

            // Detect Home Connect window reset
            if (previousRemaining != null && remainingInt > previousRemaining) {
                logInfo("Home Connect rate limit window reset (${previousRemaining} → ${remainingInt}) — resetting local counter")
                state.apiCallsTotal       = 0
                state.apiCallsByMethod    = [GET: 0, PUT: 0, DELETE: 0]
                state.apiCallsByCategory  = [:]
                state.rateLimitWarningSent= false   // Allow warnings again in new window
                sendEvent(name: "apiCallsToday", value: 0)
            }

            // FIX: Only warn/error once per rate limit period using rateLimitWarningSent flag.
            // Original logged error on EVERY trackApiCall() when remaining ≤20 — flooded the log.
            if (!state.rateLimitWarningSent) {
                if (remainingInt < 50) {
                    logError("Rate limit critical: only ${remainingInt} API calls remaining!")
                    state.rateLimitWarningSent = true
                } else if (remainingInt < 100) {
                    logWarn("Rate limit warning: only ${remainingInt} API calls remaining")
                } else if (remainingInt < 200) {
                    logWarn("Rate limit caution: ${remainingInt} API calls remaining")
                }
            }
        }

        if (limit != null) {
            sendEvent(name: "rateLimitLimit", value: limit.toString().trim().toInteger())
        }
    } catch (Exception e) {
        logWarn("Could not extract rate limit headers: ${e.message}")
    }
}

private void trackApiCall(String method, String path) {
    try {
        if (state.apiCallsTotal == null)      state.apiCallsTotal      = 0
        if (state.apiCallsByMethod == null)   state.apiCallsByMethod   = [GET: 0, PUT: 0, DELETE: 0]
        if (state.apiCallsByCategory == null) state.apiCallsByCategory = [:]

        state.apiCallsTotal = state.apiCallsTotal + 1
        state.apiCallsByMethod[method] = (state.apiCallsByMethod[method] ?: 0) + 1

        def category = categorizeApiCall(path)
        state.apiCallsByCategory[category] = (state.apiCallsByCategory[category] ?: 0) + 1

        sendEvent(name: "apiCallsToday", value: state.apiCallsTotal)

        // FIX: Threshold warnings now handled in extractRateLimitHeaders() with rateLimitWarningSent flag.
        // Removed per-call error logging here that fired on every call when remaining ≤20.

    } catch (Exception e) {
        logDebug("Error tracking API call: ${e.message}")
    }
}

private String categorizeApiCall(String path) {
    if (path == null) return "unknown"
    if (path.contains("/programs/available")) return "programs"
    if (path.contains("/programs/active"))    return "programs"
    if (path.contains("/programs/selected"))  return "programs"
    if (path.contains("/status"))             return "status"
    if (path.contains("/settings"))           return "settings"
    if (path.contains("/commands"))           return "commands"
    if (path.contains("/images"))             return "images"
    if (path.endsWith("/homeappliances"))     return "discovery"
    return "other"
}

def showApiUsage() {
    def total      = state.apiCallsTotal    ?: 0
    def byMethod   = state.apiCallsByMethod ?: [:]
    def byCategory = state.apiCallsByCategory ?: [:]
    def remaining  = device.currentValue("rateLimitRemaining")
    def limit      = device.currentValue("rateLimitLimit")
    log.info "==================== API USAGE ===================="
    log.info "Calls tracked this window: ${total}"
    if (remaining != null && limit != null) { log.info "API-reported: ${remaining} / ${limit} remaining" }
    else if (remaining != null)             { log.info "API-reported remaining: ${remaining}" }
    log.info "By method:   GET=${byMethod.GET ?: 0}  PUT=${byMethod.PUT ?: 0}  DELETE=${byMethod.DELETE ?: 0}"
    byCategory.sort().each { cat, count -> log.info "  ${cat}: ${count}" }
    log.info "(Counter resets automatically when Home Connect's window resets)"
    log.info "==================================================="
}

def resetApiCounter() {
    state.apiCallsTotal      = 0
    state.apiCallsByMethod   = [GET: 0, PUT: 0, DELETE: 0]
    state.apiCallsByCategory = [:]
    state.rateLimitWarningSent = false
    sendEvent(name: "apiCallsToday", value: 0)
    logInfo("API call counter reset")
}

private void handleHttpError(String method, String path, groovyx.net.http.HttpResponseException e, Closure closure) {
    def statusCode   = e.getStatusCode()
    def responseData = e.getResponse()?.getData()

    try { extractRateLimitHeaders(e.getResponse()) } catch (Exception ex) { /* ignore */ }

    switch (statusCode) {
        case 401:
            logWarn("API ${method} 401 Unauthorized — refreshing token")
            if (parent?.refreshOAuthTokenAndRetry()) {
                logInfo("Retrying API ${method} after token refresh")
                switch (method) {
                    case "GET":    apiGetRetry(path, closure);    break
                    case "DELETE": apiDeleteRetry(path, closure); break
                    default:       logWarn("${method} retry not implemented — please retry manually")
                }
            }
            break
        case 404:
            if (path.contains('programs/active')) { logDebug("No active program (appliance idle)") }
            else                                  { logWarn("API ${method} 404 Not Found: ${path}") }
            break
        case 409:
            def reasonInfo = extractConflictReason(responseData, path)
            if (method == "GET") {
                logInfo("API GET 409 — ${reasonInfo.message}")
            } else {
                logWarn("API ${method} 409 — ${reasonInfo.message}")
                def haId = extractHaIdFromPath(path)
                if (haId) parent?.handleCommandError(haId, reasonInfo.errorType, reasonInfo.message)
            }
            break
        case 429:
            logError("API ${method} 429 Rate Limited")
            sendEvent(name: "rateLimitRemaining", value: 0)
            def rateLimitBackoff = now() + (3600 * 1000)
            if (!state.rateLimitedUntil || state.rateLimitedUntil < rateLimitBackoff) {
                state.rateLimitedUntil          = rateLimitBackoff
                state.rateLimitedUntilFormatted = formatDateTime(rateLimitBackoff)
                state.rateLimitWarningSent      = true
                sendEvent(name: "connectionStatus", value: "rate limited until ${state.rateLimitedUntilFormatted}")
                logError("Rate limited until ${state.rateLimitedUntilFormatted}")
            }
            break
        case 503:
            logWarn("API ${method} 503 Service Unavailable — appliance may be offline")
            def haId503 = extractHaIdFromPath(path)
            if (haId503) parent?.handleCommandError(haId503, "Service unavailable", "appliance may be offline or network issue")
            break
        default:
            logError("API ${method} error ${statusCode}: ${responseData} — path: ${path}")
    }
}

private Map extractConflictReason(def responseData, String path = null) {
    def target = extractTargetFromPath(path)
    if (!responseData) return [errorType: "Conflict", message: "Command rejected — appliance not ready (check door, power, remote control)"]
    try {
        def errorKey  = responseData?.error?.key         ?: ""
        def errorDesc = responseData?.error?.description ?: ""
        if (errorKey) return translateApiError(errorKey, errorDesc, target)
    } catch (Exception e) { /* fall through */ }
    def s = responseData.toString().toLowerCase()
    if      (s.contains("door"))      return [errorType: "Door",           message: "Command rejected — door may be open${target ? ' (' + target + ')' : ''}"]
    else if (s.contains("remote"))    return [errorType: "Remote Control", message: "Command rejected — remote control not active or not allowed"]
    else if (s.contains("power"))     return [errorType: "Power",          message: "Command rejected — appliance may be off or in standby"]
    else if (s.contains("operation")) return [errorType: "Operation",      message: "Command rejected — appliance is busy or transitioning states"]
    else                              return [errorType: "Conflict",        message: "Command rejected — appliance not ready (check door, power, remote control)"]
}

private Map translateApiError(String errorKey, String errorDesc, String target) {
    def shortKey   = errorKey.contains(".") ? errorKey.substring(errorKey.lastIndexOf(".") + 1) : errorKey
    def targetInfo = target ? " '${target}'" : ""
    switch (shortKey) {
        case "UnsupportedSetting":      return [errorType: "Not Supported", message: "Setting${targetInfo} is not supported by this appliance"]
        case "UnsupportedOption":       return [errorType: "Not Supported", message: "Option${targetInfo} is not supported by this appliance"]
        case "UnsupportedCommand":      return [errorType: "Not Supported", message: "Command${targetInfo} is not supported by this appliance"]
        case "UnsupportedOperation":    return [errorType: "Not Supported", message: "Operation${targetInfo} is not supported in its current state"]
        case "UnsupportedProgram":      return [errorType: "Not Supported", message: "Program${targetInfo} is not supported by this appliance"]
        case "InvalidOptionValue":      return [errorType: "Invalid Value", message: "Invalid value for${targetInfo}${errorDesc ? ' - ' + errorDesc : ''}"]
        case "InvalidSettingValue":     return [errorType: "Invalid Value", message: "Invalid value for setting${targetInfo}${errorDesc ? ' - ' + errorDesc : ''}"]
        case "ReadOnlySetting":         return [errorType: "Read Only",     message: "Setting${targetInfo} is read-only and cannot be changed"]
        case "DoorOpen":                return [errorType: "Door",          message: "Command rejected — door is open"]
        case "NotInRemoteControlMode":
        case "RemoteControlNotActive":  return [errorType: "Remote Control",message: "Remote control is not active — enable it on the appliance first"]
        case "RemoteStartNotAllowed":
        case "NotInRemoteStartMode":    return [errorType: "Remote Start",  message: "Remote start not allowed — enable remote start on the appliance first"]
        case "ActiveProgramNotSet":     return [errorType: "No Program",    message: "No program is currently active"]
        case "ProgramNotAvailable":     return [errorType: "Not Available", message: "Program${targetInfo} is not available in the current state"]
        case "InvalidSettingState":     return [errorType: "Not Available", message: "Setting${targetInfo} is currently not available or writable"]
        case "SelectedProgramNotSet":   return [errorType: "No Program",    message: "No program selected — select or start a program first"]
        case "AlreadyInSelectedState":  return [errorType: "Already Set",   message: "Appliance is already in the requested state"]
        case "WrongOperationState":     return [errorType: "Wrong State",   message: "Command rejected — appliance not in the right state${errorDesc ? ' (' + errorDesc + ')' : ''}"]
        default:                        return [errorType: shortKey,         message: "${errorKey}${errorDesc ? ': ' + errorDesc : ''}${targetInfo ? ' for' + targetInfo : ''}"]
    }
}

private String extractTargetFromPath(String path) {
    if (!path) return null
    try {
        if (path.contains("/settings/")) {
            def k = path.substring(path.lastIndexOf("/settings/") + 10)
            if (k) return k.contains(".") ? k.substring(k.lastIndexOf(".") + 1) : k
        }
        if (path.contains("/programs/active")) return null
        if (path.contains("/options/")) {
            def k = path.substring(path.lastIndexOf("/options/") + 9)
            if (k) return k.contains(".") ? k.substring(k.lastIndexOf(".") + 1) : k
        }
    } catch (Exception e) { /* don't fail on path parsing */ }
    return null
}

private String extractHaIdFromPath(String path) {
    if (!path) return null
    def matcher = path =~ /\/api\/homeappliances\/([^\/]+)/
    return (matcher && matcher.size() > 0 && matcher[0].size() > 1) ? matcher[0][1] : null
}

private void apiGetRetry(String path, Closure closure) {
    def token = parent?.getOAuthToken()
    if (!token) { logError("No OAuth token for API GET retry"); return }
    trackApiCall("GET", path)
    try {
        httpGet(uri: getApiUrl() + path, contentType: "application/json",
                headers: ['Authorization': "Bearer ${token}", 'Accept-Language': parent?.getLanguage() ?: "en-US", 'Accept': "application/vnd.bsh.sdk.v1+json"]
        ) { response -> logDebug("API GET retry: ${response.status}"); extractRateLimitHeaders(response); if (response.data) closure(response.data) }
    } catch (Exception e) { logError("API GET retry failed: ${e.message}") }
}

private void apiDeleteRetry(String path, Closure closure) {
    def token = parent?.getOAuthToken()
    if (!token) { logError("No OAuth token for API DELETE retry"); return }
    trackApiCall("DELETE", path)
    try {
        httpDelete(uri: getApiUrl() + path, contentType: "application/json", requestContentType: "application/json",
                   headers: ['Authorization': "Bearer ${token}", 'Accept-Language': parent?.getLanguage() ?: "en-US", 'Accept': "application/vnd.bsh.sdk.v1+json"]
        ) { response -> logDebug("API DELETE retry: ${response.status}"); extractRateLimitHeaders(response); if (response.data) closure(response.data) }
    } catch (Exception e) { logError("API DELETE retry failed: ${e.message}") }
}

