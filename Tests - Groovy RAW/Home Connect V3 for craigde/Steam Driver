@Field static final String  DEFAULT_API_URL         = "https://api.home-connect.com"
@Field static final String  ENDPOINT_APPLIANCES     = "/api/homeappliances"
@Field static final String  DRIVER_VERSION          = "3.3.25"

@Field static final Integer NORMAL_RECONNECT_DELAY  = 300     // 5 min after normal disconnect
@Field static final Integer MAX_RECONNECT_ATTEMPTS  = 10
@Field static final Integer RATE_LIMIT_BUFFER       = 300     // 5 min buffer after rate limit expires

private String getApiUrl() {
    return state.apiUrl ?: DEFAULT_API_URL
}

/* ===========================================================================================================
   LIFECYCLE METHODS
   =========================================================================================================== */

def installed() {
    log.info "Home Connect Stream Driver v${DRIVER_VERSION} installed"
    sendEvent(name: "driverVersion",    value: DRIVER_VERSION)
    sendEvent(name: "connectionStatus", value: "disconnected")
}

def updated() {
    log.info "Home Connect Stream Driver v${DRIVER_VERSION} updated"
    def previousVersion = device.currentValue("driverVersion")
    sendEvent(name: "driverVersion", value: DRIVER_VERSION)

    // Manage debug auto-disable schedule
    unschedule("disableDebugLogging")
    if (debugLogging && settings?.debugAutoDisable != "manual") {
        def minutes = settings?.debugAutoDisable?.toInteger() ?: 30
        log.info "Debug logging will auto-disable in ${minutes} minutes"
        runIn(minutes * 60, "disableDebugLogging")
    }

    if (previousVersion != DRIVER_VERSION) {
        logInfo("Driver updated from ${previousVersion} to ${DRIVER_VERSION} — re-initializing")
        runIn(1, "initialize")
    }
}

def disableDebugLogging() {
    log.info "Home Connect Stream: auto-disabling debug/trace logging"
    device.updateSetting("debugLogging",  [value: false, type: "bool"])
    device.updateSetting("traceLogging",  [value: false, type: "bool"])
}

def initialize() {
    logInfo("Initializing Home Connect Stream Driver v${DRIVER_VERSION}")
    sendEvent(name: "driverVersion", value: DRIVER_VERSION)

    // Replace aggressive watchdog cron with lightweight health monitor
    // Health monitor only logs warnings — never forces reconnect
    unschedule("streamWatchdog")
    unschedule("streamHealthMonitor")
    if ((settings?.streamHealthAlertMinutes ?: "10") != "0") {
        schedule("0 */5 * * * ?", "streamHealthMonitor")
        logDebug("Stream health monitor scheduled (alert threshold: ${settings?.streamHealthAlertMinutes ?: 10}min)")
    }

    state.processingDisconnect = false
    state.pendingReconnectTime = null

    connect()
}

private void checkDriverVersion() {
    if (device.currentValue("driverVersion") != DRIVER_VERSION) {
        sendEvent(name: "driverVersion", value: DRIVER_VERSION)
        logInfo("Driver code updated to v${DRIVER_VERSION} — scheduling re-initialization")
        runIn(2, "initialize")
    }
}

def refresh() {
    logInfo("Refreshing connection")
    sendEvent(name: "driverVersion", value: DRIVER_VERSION)
    disconnect()
    runIn(2, "connect")
}

/* ===========================================================================================================
   SSE CONNECTION MANAGEMENT
   =========================================================================================================== */

def connect() {
    unschedule("connect")
    state.pendingReconnectTime = null   // Clear pending reconnect flag — we're connecting now
    state.processingDisconnect = false

    def currentStatus = device.currentValue("connectionStatus")
    if (currentStatus == "connected") {
        logDebug("Already connected — ignoring duplicate connect() call")
        return
    }
    if (currentStatus == "connecting") {
        def connectStart = state.lastConnectAttemptTime ?: 0
        if (connectStart > 0 && (now() - connectStart) < 60000) {
            logDebug("Already connecting (${((now() - connectStart) / 1000).toInteger()}s ago) — waiting")
            return
        }
        logWarn("Stuck in 'connecting' state for over 60s — forcing reconnect")
        sendEvent(name: "connectionStatus", value: "disconnected")
    }

    if (state.rateLimitedUntil && now() < state.rateLimitedUntil) {
        def rateLimitTime = state.rateLimitedUntilFormatted ?: formatDateTime(state.rateLimitedUntil)
        logWarn("Cannot connect — rate limited until ${rateLimitTime}")
        sendEvent(name: "connectionStatus", value: "rate limited until ${rateLimitTime}")
        return
    }

    if (state.rateLimitedUntil && now() >= state.rateLimitedUntil) {
        state.rateLimitedUntil = null
        state.rateLimitedUntilFormatted = null
        state.reconnectAttempts = 0
        // Reset rate limit warning flag so warnings fire again in the new window
        state.rateLimitWarningSent = false
        logInfo("Rate limit expired — cleared")
    }

    logDebug("Connecting to Home Connect event stream")

    def token = parent?.getOAuthToken()
    if (!token) {
        logError("No OAuth token available — cannot connect")
        sendEvent(name: "connectionStatus", value: "error - no token")
        return
    }

    try {
        def tokenExpires = parent?.getTokenExpiryTime() ?: 0
        def tokenAge = tokenExpires > 0 ? (tokenExpires - now()) / 1000 : -1
        logDebug("OAuth token valid for ${tokenAge}s more")
    } catch (Exception e) { /* parent app may not have getTokenExpiryTime() */ }

    def language = parent?.getLanguage() ?: "en-US"
    def apiUrl   = getApiUrl()
    logDebug("Connecting to: ${apiUrl}${ENDPOINT_APPLIANCES}/events")

    state.lastConnectAttemptTime = now()

    try {
        interfaces.eventStream.connect(
            "${apiUrl}${ENDPOINT_APPLIANCES}/events",
            [
                rawData: true,
                ignoreSSLIssues: true,
                headers: [
                    'Authorization' : "Bearer ${token}",
                    'Accept'        : 'text/event-stream',
                    'Accept-Language': language
                ]
            ]
        )
        sendEvent(name: "connectionStatus", value: "connecting")
    } catch (Exception e) {
        logError("Failed to connect: ${e.message}")
        sendEvent(name: "connectionStatus", value: "error")
    }
}

def disconnect() {
    logInfo("Disconnecting from Home Connect event stream")
    unschedule("connect")
    state.pendingReconnectTime = null

    try {
        interfaces.eventStream.close()
    } catch (Exception e) {
        logWarn("Error during disconnect: ${e.message}")
    }
    sendEvent(name: "connectionStatus", value: "disconnected")
    state.processingDisconnect = false
}

def clearRateLimit() {
    logInfo("Clearing local rate limit state manually")
    logWarn("Note: This clears LOCAL rate limit tracking only. If Home Connect's server-side " +
            "limit is still active, connecting will re-trigger it. Wait for the full period to expire.")
    unschedule("connect")
    state.rateLimitedUntil          = null
    state.rateLimitedUntilFormatted = null
    state.reconnectAttempts         = 0
    state.processingDisconnect      = false
    state.rateLimitWarningSent      = false
    state.pendingReconnectTime      = null
    sendEvent(name: "connectionStatus",   value: "disconnected")
    sendEvent(name: "rateLimitRemaining", value: 0)
}

def reconnect() {
    logInfo("Reconnecting stream (user-requested)")
    disconnect()
    runIn(2, "connect")
}

def showEventStats() {
    logInfo("=== Event Statistics ===")
    if (state.eventStats) {
        state.eventStats.each { type, count -> logInfo("${type}: ${count} events") }
        if (state.lastRealEventTime) {
            def lastRealEventAgo = (now() - state.lastRealEventTime) / 1000
            logInfo("Last real event: ${state.lastRealEventType} (${lastRealEventAgo.toInteger()}s ago)")
        } else {
            logInfo("No real events received yet (only keep-alives)")
        }
    } else {
        logInfo("No events received yet")
    }
    logInfo("======================")
}

def clearEventStats() {
    logInfo("Clearing event statistics")
    state.eventStats              = [:]
    state.lastRealEventTime       = null
    state.lastRealEventType       = null
    state.applianceLastEventTime  = [:]
    state.applianceLastEventType  = [:]
    state.applianceLastEventKey   = [:]
}

def showStreamHealth() {
    def lastParse = state.lastParseTime ?: 0
    def parseElapsed
    if (lastParse > 0) {
        parseElapsed = now() - lastParse
    } else {
        def fallback = state.lastRealEventTime ?: state.connectionStartTime ?: 0
        parseElapsed = fallback > 0 ? (now() - fallback) : 0
        if (fallback > 0) logWarn("showStreamHealth: lastParseTime missing, using fallback")
    }
    logStreamHealthDiagnostics(parseElapsed)
}

/* ===========================================================================================================
   SSE EVENT STATUS HANDLER
   =========================================================================================================== */

def eventStreamStatus(String status) {
    logDebug("Event stream status: ${status}")

    if (status.contains("START")) {
        sendEvent(name: "connectionStatus", value: "connected")
        messageBuffer = ""

        state.connectionSucceeded   = true
        state.reconnectAttempts     = 0
        state.lastConnectTime       = now()
        state.connectionStartTime   = now()
        state.lastParseTime         = now()
        state.processingDisconnect  = false
        state.pendingReconnectTime  = null

        unschedule("streamWatchdog")
        unschedule("streamHealthMonitor")
        if ((settings?.streamHealthAlertMinutes ?: "10") != "0") {
            schedule("0 */5 * * * ?", "streamHealthMonitor")
        }

        // Only refresh device status if background polling is NOT disabled
        def previousDisconnectTime = state.lastDisconnectTime ?: 0
        if (previousDisconnectTime > 0 && !settings?.disableBackgroundPolling) {
            def disconnectedSec = ((now() - previousDisconnectTime) / 1000).toInteger()
            logInfo("Reconnected after ${disconnectedSec}s — scheduling device status refresh")
            runIn(5, "notifyParentReconnected")
        } else if (settings?.disableBackgroundPolling) {
            logDebug("Reconnected — device refresh on reconnect is disabled")
        }

    } else if (status.contains("STOP") || status.contains("ERROR")) {
        if (state.processingDisconnect) {
            logDebug("Already processing disconnect — ignoring duplicate event")
            return
        }
        state.processingDisconnect = true

        if (state.rateLimitedUntil && now() < state.rateLimitedUntil) {
            def rateLimitTime = state.rateLimitedUntilFormatted ?: formatDateTime(state.rateLimitedUntil)
            sendEvent(name: "connectionStatus", value: "rate limited until ${rateLimitTime}")
            logWarn("Stream disconnected while rate limited — status preserved")
        } else {
            sendEvent(name: "connectionStatus", value: "disconnected")
        }
        state.lastDisconnectTime = now()

        if (status.contains("Too many follow-up requests") || status.contains("ProtocolException")) {
            handleFollowUpRequestsError(status)
            return
        }

        if (state.rateLimitedUntil && now() < state.rateLimitedUntil) {
            logWarn("Rate limited — not reconnecting")
            return
        }

        unschedule("connect")

        Integer delay
        if (state.connectionSucceeded) {
            state.connectionSucceeded = false
            delay = NORMAL_RECONNECT_DELAY
            logDebug("Normal disconnect — scheduling reconnect in ${delay}s")
        } else {
            def attempts = (state.reconnectAttempts ?: 0) + 1
            state.reconnectAttempts = attempts
            if (attempts > MAX_RECONNECT_ATTEMPTS) {
                logError("Max reconnect attempts (${MAX_RECONNECT_ATTEMPTS}) reached — manual reconnect required")
                sendEvent(name: "connectionStatus", value: "failed - manual reconnect required")
                return
            }
            delay = Math.min(300, 60 * Math.pow(2, attempts - 1) as Integer)
            logWarn("Connection failed — scheduling reconnect in ${delay}s (attempt ${attempts}/${MAX_RECONNECT_ATTEMPTS})")
        }

        // Record when the reconnect is due for diagnostic purposes
        state.pendingReconnectTime = now() + (delay * 1000)
        runIn(delay, "connect")
    }
}

def notifyParentReconnected() {
    if (state.rateLimitedUntil && now() < state.rateLimitedUntil) {
        logWarn("Skipping device refresh — rate limited")
        return
    }
    def currentStatus = device.currentValue("connectionStatus")
    if (currentStatus != "connected") {
        logWarn("Skipping device refresh — no longer connected (${currentStatus})")
        return
    }
    logInfo("Notifying parent to refresh device status")
    parent?.refreshAllDeviceStatus()
}

