void getHomeDataCallback() {
    logDebug "getHomeDataCallback()"
    Boolean deviceOnline = !!(getHomeDataResult()?.devices?.find { it.duid?.toString() == getDeviceId() }?.online)
    if (!deviceOnline) {
        logWarn "device appears offline in cloud home data"
        processEvent("state", 256)
    }

    if (!settings?.deviceIP) {
        String ip = getHomeDataResult()?.devices?.find { it.duid?.toString() == getDeviceId() }?.ip
        if (ip) {
            logInfo "discovered vacuum IP from cloud: ${ip}"
            state.discoveredIP = ip
        }
    }

    String name = getHomeDataResult()?.devices?.find { it.duid?.toString() == getDeviceId() }?.name ?: "unknown"
    processEvent("name", name)

    setRoomsValueFromHomeData()
    getDeviceScenes()
    runIn(5, "startLocalMode")
}

