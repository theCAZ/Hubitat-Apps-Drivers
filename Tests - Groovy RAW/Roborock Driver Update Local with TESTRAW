// ── Local TCP mode ────────────────────────────────────────────────────────────
void startLocalMode() {
    logInfo "starting local TCP mode"
    String ip = getVacuumIP()
    if (!ip) {
        logWarn "no local IP known — check 'Vacuum Local IP Address' preference or run syncFromCloud"
        processEvent("healthStatus", "offline")
        sendEvent(name: "connectionMode", value: "offline")
        return
    }
    sendEvent(name: "localIP", value: ip)
    sendEvent(name: "connectionMode", value: "local")
    localConnect()
    schedulePoll()
    runIn(6, "forceTileUpdate")
}

void localConnect() {
    String ip = getVacuumIP()
    if (!ip) return
    logInfo "connecting local TCP to ${ip}:${ROBOROCK_LOCAL_PORT}"
    try {
        // readDelay:500 — critical for parse() to fire on binary TCP responses in Hubitat
        interfaces.rawSocket.connect(ip, ROBOROCK_LOCAL_PORT, byteInterface: true, readDelay: 500)
        state.localConnected = true
        state.lastLocalSuccess = now()
        logInfo "local TCP connected — marking online, sending initial probe"
        runIn(1, "setOnlineFromConnect")
        runIn(2, "doPollCommands")
    } catch (Exception e) {
        logWarn "local TCP connect failed: ${e.message}"
        state.localConnected = false
        scheduleReconnect()
    }
}

void localDisconnect() {
    try { interfaces.rawSocket.close() } catch (Exception e) { /* ignore */ }
    state.localConnected = false
}

void socketStatus(String message) {
    logDebug "socketStatus: ${message}"
    if (message?.toLowerCase()?.contains("error") || message?.toLowerCase()?.contains("closed")) {
        logWarn "local TCP socket issue: ${message}"
        state.localConnected = false
        scheduleReconnect()
        checkOfflineThreshold()
    }
}

void scheduleReconnect() {
    logInfo "scheduling local TCP reconnect in 15s"
    runIn(15, "localConnect")
}

void checkOfflineThreshold() {
    Integer threshold = (settings?.offlineThreshold ?: 90).toInteger()
    Long lastSuccess = state?.lastLocalSuccess ?: 0
    if ((now() - lastSuccess) > (threshold * 1000)) {
        logWarn "exceeded offline threshold (${threshold}s) — marking offline"
        processEvent("healthStatus", "offline")
        sendEvent(name: "connectionMode", value: "offline")
        if (settings?.tileEnable)   scheduleTileUpdate()
        if (settings?.xxTileEnable) scheduleXxTileUpdate()
    }
}

// ── Polling ───────────────────────────────────────────────────────────────────
void schedulePoll() {
    Integer interval = (settings?.pollInterval ?: "30").toInteger()
    logDebug "scheduling poll every ${interval}s"
    unschedule('pollStatus')
    if (interval == 30)  schedule("0/${interval} * * * * ?", "pollStatus")
    else if (interval == 60)  runEvery1Minute('pollStatus')
    else if (interval == 120) runEvery2Minutes('pollStatus')
    runIn(2, "pollStatus")
}

void pollStatus() {
    logDebug "polling vacuum status locally"
    if (!state?.localConnected) {
        localConnect()
        runIn(3, "doPollCommands")
    } else {
        doPollCommands()
    }
    runIn(4, "forceTileUpdate")
}

void forceTileUpdate() {
    if (settings?.tileEnable)   updateTile()
    if (settings?.xxTileEnable) updateXxTile()
}

void doPollCommands() {
    localExecute("get_prop", """["get_status"]""")
    state.pollCount = ((state?.pollCount ?: 0).toInteger() + 1)
    if (state.pollCount % 5 == 0) {
        runIn(2, "pollConsumables")
