    String errorHtml=hasError?"<tr><td colspan='2' style='padding:0 12px 6px 12px;'><div style='background:#4a1515;color:#fca5a5;border-radius:6px;padding:5px 9px;font-size:11px;'>&#9888; ${errorVal.capitalize()}</div></td></tr>":""
    String progressHtml=""
    if(isCleaning&&cleanPct!=null){int cp=Math.max(0,Math.min(100,cleanPct.toInteger()));progressHtml="<tr><td colspan='2' style='padding:6px 12px 0 12px;'><table style='width:100%;border-collapse:collapse;'><tr><td style='font-size:10px;color:#64748b;width:1%;white-space:nowrap;padding-right:8px;'>Progress</td><td style='padding:0;'><div style='background:#1e3a5f;border-radius:3px;height:6px;'><div style='background:#3b82f6;border-radius:3px;height:6px;width:${cp}%;'></div></div></td><td style='font-size:11px;color:#60a5fa;font-weight:bold;width:1%;white-space:nowrap;padding-left:8px;'>${cp}%</td></tr></table></td></tr>"}
    String statsHtml=""
    if(cleanTime!=null||cleanArea!=null){String cl=isCleaning?"Current":"Last";List pts=[];if(cleanTime!=null)pts<<"${cleanTime.toInteger()} min";if(cleanArea!=null)pts<<"${cleanArea.toInteger()} sq ft";statsHtml="<div style='font-size:11px;color:#64748b;margin-top:3px;'>${cl}: ${pts.join(' &nbsp;&#183;&nbsp; ')}</div>"}
    Closure bar={Double pct,String label->int p=Math.max(0,Math.min(100,pct.toInteger()));String bc=p>=50?"#16a34a":p>=25?"#d97706":"#dc2626";String track=p>=50?"#0d2a1a":p>=25?"#2a1a05":"#2a0a0a";String pc2=p>=50?"#4ade80":p>=25?"#fbbf24":"#f87171";String bold=p<25?"font-weight:bold;":"";return "<tr><td style='font-size:11px;color:#64748b;padding:3px 8px 3px 0;white-space:nowrap;width:1%;'>${label}</td><td style='padding:3px 0;'><div style='background:${track};border-radius:3px;height:5px;'><div style='background:${bc};border-radius:3px;height:5px;width:${p}%;'></div></div></td><td style='font-size:11px;color:${pc2};padding:3px 0 3px 8px;white-space:nowrap;width:1%;text-align:right;${bold}'>${p}%</td></tr>"}
