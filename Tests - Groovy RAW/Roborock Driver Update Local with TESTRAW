void clearAttributes() {
    device.currentStates?.collect { ((new JsonSlurper().parseText(JsonOutput.toJson(it)))?.name) }
          ?.each { device.deleteCurrentState(it) }
}

void cleanStaleAttributes() {
    List stale = ["cleanTime", "cleanArea", "cleanPercent", "remainingFilter", "remainingMainBrush",
                  "remainingSensors", "remainingSideBrush", "remainingHighSpeedMaintBrush", "rooms", "scenes"]
    device.currentStates?.collect { ((new JsonSlurper().parseText(JsonOutput.toJson(it)))?.name) }
          ?.each { n -> if (stale.contains(n)) { device.deleteCurrentState(n); logInfo "removed stale: $n" } }
}

