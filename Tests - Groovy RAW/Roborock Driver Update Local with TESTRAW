def logsOff() {
    log.info "${device.displayName} auto-disabling logging"
    device.updateSetting("deviceLogging", [value: "off", type: "enum"])
}
void scheduleLogsOff() {
    unschedule('logsOff')
    def s = settings?.deviceLogging ?: "off"
    if (s == "off") return
    def minutes = s.endsWith("60") ? 60 : 30
    runIn(minutes * 60, "logsOff")
}

// ── Lifecycle ─────────────────────────────────────────────────────────────────
def installed() { initialize() }

def updated() {
    cleanStaleAttributes()
    scheduleLogsOff()
    initialize()
    scheduleLogsOff()
}

def initialize() {
    unschedule()
    scheduleLogsOff()
    sendEvent(name: "numberOfButtons", value: (settings?.numberOfButtons) ?: 1)
    localDisconnect()

    if (settings?.allowLogin && settings?.username && settings?.password) {
        logInfo "executing 'initialize()' — cloud login"
        state?.keySet()?.collect()?.each { state.remove(it) }
        state.sequence = (new Random().nextInt(2000) + 1)
        clearAttributes()

        Map login = login()
        device.updateSetting("allowLogin", [value: 'false', type: "bool"])

        if (login?.msg == "success") {
            runIn(1, "getHomeDetail")
        } else {
            logWarn "login failed: ${login?.msg}"
            processEvent("state", 500)
        }
    } else if (state?.login) {
        runIn(2, "startLocalMode")
    }
}

