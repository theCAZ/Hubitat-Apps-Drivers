def testLocalRaw() {
    log.warn "${device.displayName} testLocalRaw: closing any existing socket"
    try { interfaces.rawSocket.close() } catch (Exception e) { /* ignore */ }
    pauseExecution(500)

    String ip = getVacuumIP()
    if (!ip) {
        log.error "${device.displayName} testLocalRaw: no IP — set 'Vacuum Local IP Address' in preferences first"
        return
    }

    log.warn "${device.displayName} testLocalRaw: connecting to ${ip}:${ROBOROCK_LOCAL_PORT} with readDelay:500"
    try {
        // readDelay:500 — waits 500ms between reads, known to help parse() fire on binary responses
        interfaces.rawSocket.connect(ip, ROBOROCK_LOCAL_PORT, byteInterface: true, readDelay: 500)
        state.localConnected = true
        log.warn "${device.displayName} testLocalRaw: connected — pausing 1s then sending get_status"
        pauseExecution(1000)
        localExecute("get_prop", """["get_status"]""")
        log.warn "${device.displayName} testLocalRaw: command sent — if parse() fires you will see it above within 3s"
    } catch (Exception e) {
        log.error "${device.displayName} testLocalRaw: connect/send failed: ${e.message}"
        state.localConnected = false
    }
}

