def zRequestEmailCode() {
    if (state.sendEmailCodeTimestamp) {
        Long remaining = (state.sendEmailCodeTimestamp as Long) + 60000 - now()
        if (remaining > 0) { logWarn "wait ${(remaining / 1000).toInteger()}s before requesting again"; return }
    }
    state.sendEmailCodeTimestamp = now()
    Map result = sendEmailCode()
    if (result.msg == "success") { processEvent("state", 502) }
    else { logWarn "request email code failed: ${result?.msg}"; processEvent("state", 504) }
}

def zAuthorizeEmailCode(String pin) {
    logInfo "executing 'zAuthorizeEmailCode($pin)'"
    if (!pin || !state?.sendEmailCodeTimestamp || now() > ((state.sendEmailCodeTimestamp as Long) + 15 * 60 * 1000)) {
        logWarn "code expired or missing"; return
    }
    Map result = loginWithCode(pin)
    if (result?.msg == "success") {
        processEvent("state", 503)
        runIn(1, "getHomeDetail")
        state.remove("sendEmailCodeTimestamp")
    } else {
        logWarn "authorize email code failed: ${result?.msg}"
        processEvent("state", 500)
    }
}

