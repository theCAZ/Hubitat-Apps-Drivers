@Field volatile static Map<Long, Long> g_mLastTileTime   = [:]
@Field volatile static Map<Long, Long> g_mLastXxTileTime = [:]

void scheduleTileUpdate() {
    Long last = g_mLastTileTime[device.getIdAsLong()] ?: 0
    if ((now() - last) > 30000) { g_mLastTileTime[device.getIdAsLong()] = now(); runIn(2, "updateTile") }
    else runIn(35, "updateTile")
}

void scheduleXxTileUpdate() {
    Long last = g_mLastXxTileTime[device.getIdAsLong()] ?: 0
    if ((now() - last) > 30000) { g_mLastXxTileTime[device.getIdAsLong()] = now(); runIn(3, "updateXxTile") }
    else runIn(36, "updateXxTile")
}

