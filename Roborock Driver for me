// ============================================================
// ===================== HTML TILE (device page) =============
// ============================================================
// Enable via "Enable HTML status tile" preference.
// Use the 'html' attribute in an Attribute template tile on
// the device page. Full-featured, no character limit concern.
// ============================================================
void updateTile() {
    if (!settings?.tileEnable) return

    Closure a = { String n ->
        def v = device.currentValue(n)
        if (v == null) return null
        def s = v.toString().trim()
        (s == "" || s == "null") ? null : s
    }
    Closure aNum = { String n ->
        def v = a(n); if (v == null) return null
        try { return v.toDouble() } catch(e) { return null }
    }

    String  nameVal    = a("name")                          ?: device.displayName
    String  stateVal   = a("state")
    String  healthVal  = a("healthStatus")
    String  errorVal   = a("error")
    Double  battVal    = aNum("battery")
    Double  cleanTime  = aNum("cleanTime (min)")
    Double  cleanArea  = aNum("cleanArea (sq ft)")
    Double  cleanPct   = aNum("cleanPercent (%)")
    Double  filterPct  = aNum("remainingFilter (%)")
    Double  mainPct    = aNum("remainingMainBrush (%)")
    Double  sidePct    = aNum("remainingSideBrush (%)")
    String  dustVal    = a("dustCollection")
    String  roomsVal   = a("roomsList")

    String stateDisp  = stateVal ? stateVal.capitalize() : "Unknown"
    boolean online    = (healthVal == "online")
    boolean hasError  = errorVal && errorVal != "no error"
    boolean isCleaning = stateVal in ["cleaning", "spot cleaning", "room clean", "zone clean", "go to", "mapping"]
    boolean isDocked   = stateVal in ["charged", "charging", "docking", "returning dock", "emptying dust bin", "washing the mop"]

    String dotBg    = online ? "#1a4731" : "#4a1515"
    String dotColor = online ? "#4ade80" : "#f87171"
    String dotLabel = online ? "Online"  : "Offline"
    String stateBg   = isCleaning ? "#0d3060" : isDocked ? "#0d2a1a" : "#162032"
    String stateColor = isCleaning ? "#60a5fa" : isDocked ? "#4ade80" : "#94a3b8"
    String battLine = battVal != null ? " &nbsp;&#183;&nbsp; ${battVal.toInteger()}%" : ""

    String dustHtml = ""
    if (dustVal != null) {
        String dustBg    = dustVal == "on" ? "#1a3a6e" : "#1a2535"
        String dustColor = dustVal == "on" ? "#60a5fa" : "#475569"
        dustHtml = "<span style='font-size:10px;background:${dustBg};color:${dustColor};padding:2px 8px;border-radius:8px;margin-left:6px;'>Dust: ${dustVal}</span>"
    }

    String errorHtml = ""
    if (hasError) {
        errorHtml = """<tr><td colspan='2' style='padding:0 12px 6px 12px;'>
  <div style='background:#4a1515;color:#fca5a5;border-radius:6px;padding:5px 9px;font-size:11px;'>&#9888; ${errorVal.capitalize()}</div>
</td></tr>"""
    }

    String progressHtml = ""
    if (isCleaning && cleanPct != null) {
        int cp = Math.max(0, Math.min(100, cleanPct.toInteger()))
        progressHtml = """<tr><td colspan='2' style='padding:6px 12px 0 12px;'>
  <table style='width:100%;border-collapse:collapse;'>
  <tr>
    <td style='font-size:10px;color:#64748b;width:1%;white-space:nowrap;padding-right:8px;'>Progress</td>
    <td style='padding:0;'>
      <div style='background:#1e3a5f;border-radius:3px;height:6px;'>
        <div style='background:#3b82f6;border-radius:3px;height:6px;width:${cp}%;'></div>
      </div>
    </td>
    <td style='font-size:11px;color:#60a5fa;font-weight:bold;width:1%;white-space:nowrap;padding-left:8px;'>${cp}%</td>
  </tr>
  </table>
</td></tr>"""
    }

    String statsHtml = ""
    if (cleanTime != null || cleanArea != null) {
        String cleaningLabel = isCleaning ? "Current" : "Last"
        List parts = []
        if (cleanTime != null) parts << "${cleanTime.toInteger()} min"
        if (cleanArea != null) parts << "${cleanArea.toInteger()} sq ft"
        statsHtml = "<div style='font-size:11px;color:#64748b;margin-top:3px;'>${cleaningLabel}: ${parts.join(" &nbsp;&#183;&nbsp; ")}</div>"
    }

    Closure bar = { Double pct, String label ->
        int p = Math.max(0, Math.min(100, pct.toInteger()))
        String bc    = p >= 50 ? "#16a34a" : p >= 25 ? "#d97706" : "#dc2626"
        String track = p >= 50 ? "#0d2a1a" : p >= 25 ? "#2a1a05" : "#2a0a0a"
        String pc    = p >= 50 ? "#4ade80" : p >= 25 ? "#fbbf24" : "#f87171"
        String bold  = p < 25 ? "font-weight:bold;" : ""
        """<tr>
  <td style='font-size:11px;color:#64748b;padding:3px 8px 3px 0;white-space:nowrap;width:1%;'>${label}</td>
  <td style='padding:3px 0;'>
    <div style='background:${track};border-radius:3px;height:5px;'>
      <div style='background:${bc};border-radius:3px;height:5px;width:${p}%;'></div>
    </div>
  </td>
  <td style='font-size:11px;color:${pc};padding:3px 0 3px 8px;white-space:nowrap;width:1%;text-align:right;${bold}'>${p}%</td>
</tr>"""
    }

    boolean hasBars = (filterPct != null || mainPct != null || sidePct != null)
    String barsHtml = ""
    if (hasBars) {
        String rows = ""
        if (filterPct != null) rows += bar(filterPct, "Filter")
        if (mainPct   != null) rows += bar(mainPct,   "Main brush")
        if (sidePct   != null) rows += bar(sidePct,   "Side brush")
        barsHtml = """<tr><td colspan='2' style='padding:8px 12px 0 12px;border-top:1px solid #1e3a5f;margin-top:4px;'>
  <table style='width:100%;border-collapse:collapse;'>${rows}</table>
</td></tr>"""
    }

    String roomsHtml = ""
    if (roomsVal) {
        List allRooms = roomsVal.split("\\|").collect { it.trim() }
        int extra     = allRooms.size() - 5
        List shown    = allRooms.take(5)
        String suffix = extra > 0 ? " <span style='color:#334d6e;'>+${extra} more</span>" : ""
        String roomsFormatted = shown.join(" &nbsp;&#183;&nbsp; ") + suffix
        roomsHtml = """<tr><td colspan='2' style='padding:6px 12px 0 12px;border-top:1px solid #1e3a5f;'>
  <div style='font-size:10px;color:#64748b;line-height:1.6;'>${roomsFormatted}</div>
</td></tr>"""
    }

    String ts = new Date().format("MM/dd HH:mm", location.timeZone)

    String html = """<table style='width:100%;border-collapse:collapse;font-family:sans-serif;background:#0a1628;border-radius:10px;'>
${errorHtml}
<tr><td colspan='2' style='padding:10px 12px 6px 12px;'>
  <table style='width:100%;border-collapse:collapse;'>
  <tr>
    <td style='font-size:13px;font-weight:bold;color:#e2e8f0;'>${nameVal}${dustHtml}</td>
    <td style='text-align:right;'><span style='font-size:10px;background:${dotBg};color:${dotColor};padding:2px 9px;border-radius:10px;font-weight:bold;'>${dotLabel}</span></td>
  </tr>
  </table>
</td></tr>
<tr><td colspan='2' style='padding:0 12px 6px 12px;'>
  <div style='background:${stateBg};border-radius:7px;padding:8px 10px;border-left:3px solid ${stateColor};'>
    <div style='font-size:15px;font-weight:bold;color:#f1f5f9;'>${stateDisp}${battLine}</div>
    ${statsHtml}
  </div>
</td></tr>
${progressHtml}
${barsHtml}
${roomsHtml}
<tr><td colspan='2' style='padding:6px 12px 8px 12px;text-align:right;font-size:10px;color:#1e3a5f;'>${ts}</td></tr>
</table>"""

    logInfo "html tile chars: ${html.length()}"
    sendEvent(name: "html", value: html, isStateChange: true)
    logDebug "html tile updated"
}

// ============================================================
// ================ DASHBOARD TILE (xxTile) ==================
// ============================================================
// Enable via "Enable compact dashboard tile" preference.
// Use the 'xxTile' attribute in an Attribute template tile on
// your HE dashboard. Rendered as a single compressed line to
// stay under the 1024 character dashboard attribute limit.
// 'xxTile' sorts to the bottom of the attribute list so it is
// easy to find on the dashboard attribute picker.
// ============================================================
void updateXxTile() {
    if (!settings?.xxTileEnable) return
    Closure a   = { String n -> def v=device.currentValue(n); if(v==null)return null; def s=v.toString().trim(); (s==""||s=="null")?null:s }
    Closure aNum= { String n -> def v=a(n); if(v==null)return null; try{return v.toDouble()}catch(e){return null} }
    String nm=a("name")?:device.displayName
    String st=a("state"); String hs=a("healthStatus"); String err=a("error")
    Double bat=aNum("battery"); Double ct=aNum("cleanTime (min)"); Double ca=aNum("cleanArea (sq ft)")
    Double fp=aNum("remainingFilter (%)"); Double mp=aNum("remainingMainBrush (%)"); Double sp=aNum("remainingSideBrush (%)")
    Double cp=aNum("cleanPercent (%)")
    String du=a("dustCollection")
    boolean on=hs=="online"
    boolean act=st in ["cleaning","spot cleaning","room clean","zone clean","go to","mapping"]
    boolean dok=st in ["charged","charging","docking","returning dock","emptying dust bin","washing the mop"]
    boolean er=err&&err!="no error"
    String sbc=act?"#0d3060":dok?"#0d2a1a":"#162032"
    String slc=act?"#60a5fa":dok?"#4ade80":"#94a3b8"
    String sd=st?st.capitalize():"Unknown"
    String bl=bat!=null?" · ${bat.toInteger()}%":""
    Closure pc={ Double p -> p>=50?"#4ade80":p>=25?"#fbbf24":"#f87171" }
    List pts=[]; if(ct!=null)pts<<"${ct.toInteger()}m"; if(ca!=null)pts<<"${ca.toInteger()}sf"
    String stats=pts?"<div style='font-size:13px;color:#64748b;margin-top:6px'>${act?'Now':'Last'}: ${pts.join(' · ')}</div>":""
    String duH=du?"<span style='font-size:11px;background:${du=='on'?'#1a3a6e':'#1a2535'};color:${du=='on'?'#60a5fa':'#475569'};padding:2px 7px;border-radius:6px;margin-left:4px'>D:${du}</span>":""
    String erH=er?"<div style='background:#4a1515;color:#fca5a5;border-radius:4px;padding:3px 7px;font-size:11px;margin-bottom:4px'>&#9888; ${err.capitalize()}</div>":""
    String bottom=""
    if(!er) {
        if(act && cp!=null) {
            int cpv=Math.max(0,Math.min(100,cp.toInteger()))
            bottom="<div style='margin-top:7px;font-size:11px;color:#64748b'>Progress <b style='color:#60a5fa'>${cpv}%</b><div style='background:#1e3a5f;border-radius:3px;height:6px;margin-top:3px'><div style='background:#3b82f6;height:6px;width:${cpv}%'></div></div></div>"
        } else if(fp!=null||mp!=null||sp!=null) {
            bottom="<div style='font-size:13px;margin-top:12px;display:flex;gap:14px'>"
            if(fp!=null)bottom+="<span style='color:#64748b'>Flt:<b style='color:${pc(fp)}'>${fp.toInteger()}%</b></span>"
            if(mp!=null)bottom+="<span style='color:#64748b'>Main:<b style='color:${pc(mp)}'>${mp.toInteger()}%</b></span>"
            if(sp!=null)bottom+="<span style='color:#64748b'>Side:<b style='color:${pc(sp)}'>${sp.toInteger()}%</b></span>"
            bottom+="</div>"
        }
    }
    String html="${erH}<div style='background:#0a1628;border-radius:10px;padding:16px;font-family:sans-serif'><div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:10px'><b style='color:#e2e8f0;font-size:14px'>${nm}${duH}</b><span style='font-size:11px;background:${on?'#1a4731':'#4a1515'};color:${on?'#4ade80':'#f87171'};padding:2px 9px;border-radius:8px'>${on?'Online':'Offline'}</span></div><div style='background:${sbc};border-radius:8px;padding:12px 14px;border-left:3px solid ${slc};'><b style='color:#f1f5f9;font-size:16px'>${sd}${bl}</b>${stats}</div>${bottom}</div>"
    logDebug "xxTile chars: ${html.length()}"
    sendEvent(name:"xxTile", value:html, isStateChange:true)
}
