        sendEventX(name: "cleanArea (sq ft)", value: area, descriptionText: "clean area is $area $unit", eventDisable: cleanAttributeDisable)
        break
    case "map_present":
    case "in_cleaning":
    case "in_returning":
    case "in_fresh_state":
    case "lab_status":
    case "water_box_status":
    case "dnd_enabled":
    case "map_status":
        break
