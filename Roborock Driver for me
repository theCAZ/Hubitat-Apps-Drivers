    return qQueue[device.getIdAsLong()]
}
    
void qPush(Map map) {
    qGet().removeIf { now() > it?.ts + 30000 }
    map.ts = now()
    qGet() << map
}

void qClear() {
    qGet().clear()
}

Map qPop() {
    if(qGet().size() > 0) {
        return qGet().remove(0)
    }
    return null
}

Map qPeek() {
    return qGet().isEmpty() ? null : qGet()[0]
}

Boolean qIsEmpty() {
    return qGet().isEmpty()
}

Integer qSize() {
    return qGet().size()
}

